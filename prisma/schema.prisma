generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === Users, Roles, Permissions ===
model User {
  id            String   @id @default(cuid())
  employeeId    String?  @unique
  email         String   @unique
  name          String
  displayName   String
  password      String   // hashed bcrypt (or hashed OTP if mustChangePassword)
  department    String?
  jobTitle      String?
  /// Formal designation used on memos / signatures (e.g. "Vice Chancellor",
  /// "Head of Department, ICT"). Distinct from jobTitle which is the
  /// professional/academic title.
  designation   String?
  phone         String?
  /// Preferred channel for workflow / SLA notifications. One of
  /// "EMAIL" | "SMS" | "WHATSAPP" | "ALL". The in-app Notification row
  /// is ALWAYS written regardless — this only gates outbound transports.
  /// TODO: surface this on the profile page (settings → notifications).
  notifyChannel String   @default("EMAIL")
  profilePhoto  String?
  /// Storage path (under uploads/signatures/) of the user's saved
  /// signature PNG. Embedded into memo PDFs when this user approves.
  signatureImage    String?
  signatureUploadedAt DateTime?
  /// Optional storage path for an office stamp/seal PNG (e.g. Registrar's
  /// circular stamp). Rendered next to the signature for officers who
  /// have one. nullable per user.
  officeStamp       String?
  /// DocuSign user GUID — links this KARU user to their DocuSign account
  /// so embedded signing impersonates the right person. Pre-provisioned
  /// in DocuSign (admin invites them once), then admin maps here.
  docusignUserId    String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  mfaEnabled    Boolean  @default(false)
  /// AES-256-GCM ciphertext of the TOTP secret (stored as base64 IV.tag.ct).
  /// Plaintext is never persisted.
  mfaSecret     String?
  /// JSON array of bcrypt hashes of one-time backup codes (each can be used
  /// once if the user loses their authenticator device).
  mfaBackupCodes Json?
  /// Counter of consecutive failed login attempts. Reset on success.
  failedLoginAttempts Int @default(0)
  /// Account is locked until this timestamp after too many failed attempts.
  lockedUntil   DateTime?
  /// JSON array of the last N bcrypt hashes used by this user. Used to
  /// reject password reuse during change-password.
  passwordHistory Json?
  /// True after an admin-initiated password reset. The user must set a
  /// new password before they can use the system.
  mustChangePassword       Boolean   @default(false)
  /// Expiry for the temporary OTP issued during admin reset. Login is
  /// rejected with a "your reset link has expired" message past this time.
  passwordResetExpiresAt   DateTime?
  /// When the password was last set by the user themselves (not by reset).
  /// Used by password-rotation policy.
  passwordChangedAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles             UserRole[]
  createdDocuments  Document[]     @relation("CreatedBy")
  auditLogs         AuditLog[]
  workflowTasks          WorkflowTask[]      @relation("Assignee")
  claimedTasks           WorkflowTask[]      @relation("TaskClaimer")
  taskComments           TaskComment[]       @relation("CommentAuthor")
  taskAttachments        TaskAttachment[]    @relation("AttachmentUploader")
  workflowPoolMemberships WorkflowPoolMember[] @relation("PoolMember")
  delegationsFrom        Delegation[]        @relation("Delegator")
  delegationsTo          Delegation[]        @relation("Delegate")
  notifications     Notification[]
  correspondencesAssigned Correspondence[] @relation("CorrespondenceAssignee")
  correspondencesCreated  Correspondence[] @relation("CorrespondenceCreator")
  documentComments        DocumentComment[]
  signatures              DocumentSignature[]
  dispositionApprovals    DispositionCertificate[] @relation("DispositionApprover")
  dispositionWitnesses    DispositionCertificate[] @relation("DispositionWitness")
  appSettingsUpdated      AppSetting[]             @relation("AppSettingUpdater")
  sessions                UserSession[]            @relation("UserSessions")
  loginOtps               LoginOtp[]               @relation("UserLoginOtps")
  shareLinksCreated       DocumentShareLink[]      @relation("ShareLinkCreator")
  captureExceptionsResolved CaptureException[]     @relation("CaptureExceptionResolver")
  approvedVersions          DocumentVersion[]       @relation("VersionApprover")
  savedSearches             SavedSearch[]
  documentRelations         DocumentRelation[]      @relation("RelationCreator")
  redactionsCreated         DocumentRedaction[]     @relation("RedactionCreator")
  documentSubscriptions     DocumentSubscription[]  @relation("DocumentWatcher")
  memoDrafts                MemoDraft[]             @relation("MemoDraftAuthor")
  presenceHeartbeats        PresenceHeartbeat[]
  dashboardLayout           DashboardLayout?

  /// Distinguished name returned by the LDAP/AD directory on the user's
  /// most recent successful bind. Allows re-syncing without an additional
  /// directory lookup by email and proves which AD object owns this row.
  ldapDn                    String?  @unique
  /// When this user last signed in via LDAP/AD (group→role mapping run).
  ldapSyncedAt              DateTime?
  /// Max security classification this user can read.
  clearanceLevel            SecurityClassification  @default(OPEN)

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[]
  users       UserRole[]
  ldapGroupMaps LdapGroupRoleMap[]
  createdAt   DateTime     @default(now())

  @@map("roles")
}

/// Maps an LDAP/AD group (by CN or full DN) to a local Role.
/// When `autoApply` is true, the LDAP sign-in flow assigns/removes the role
/// based on the user's group membership at each login. When false, the
/// mapping is informational only and requires manual review.
model LdapGroupRoleMap {
  id          String   @id @default(cuid())
  ldapGroup   String   @unique
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  autoApply   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("ldap_group_role_maps")
}

model UserRole {
  userId     String
  roleId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id       String @id @default(cuid())
  roleId   String
  resource String  // documents, workflows, admin, records, forms, reports
  action   String  // create, read, update, delete, approve, manage
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

// === Classification & Retention ===
model ClassificationNode {
  id          String  @id @default(cuid())
  code        String  @unique
  title       String
  description String?
  level       Int     // 1=Function, 2=Activity, 3=Transaction
  parentId    String?
  parent      ClassificationNode?  @relation("ClassTree", fields: [parentId], references: [id])
  children    ClassificationNode[] @relation("ClassTree")
  documents   Document[]
  retentionSchedules RetentionSchedule[]
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("classification_nodes")
}

model RetentionSchedule {
  id                   String   @id @default(cuid())
  classificationNodeId String
  classificationNode   ClassificationNode @relation(fields: [classificationNodeId], references: [id])
  activeYears          Int
  inactiveYears        Int
  totalYears           Int
  disposalAction       DisposalAction
  legalBasis           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("retention_schedules")
}

enum DisposalAction {
  DESTROY
  ARCHIVE_PERMANENT
  REVIEW
}

// === Documents ===
model Document {
  id                   String   @id @default(cuid())
  referenceNumber      String   @unique
  title                String
  description          String?
  documentType         String   // MEMO, LETTER, FORM, REPORT, STUDENT_FILE, etc.
  status               DocumentStatus @default(ACTIVE)
  /// Government-grade security classification (distinct from the records
  /// file-plan node). Gated by user clearance in buildDocumentAccessWhere.
  securityClassification SecurityClassification @default(OPEN)
  classificationNodeId String?
  classificationNode   ClassificationNode? @relation(fields: [classificationNodeId], references: [id])
  createdById          String
  createdBy            User     @relation("CreatedBy", fields: [createdById], references: [id])
  department           String
  sourceSystem         String?  // STUDENT_PORTAL, ERP, MANUAL, EMAIL
  sourceId             String?  // external ID from source system
  isVitalRecord        Boolean  @default(false)
  isOnLegalHold        Boolean  @default(false)
  legalHoldReason      String?
  legalHoldAt          DateTime?
  checkoutUserId       String?
  checkoutAt           DateTime?
  checkoutExpiresAt    DateTime?  // auto force-checkin after this time
  checkoutToken        String?    @unique // opaque token for offline lock validation
  retentionExpiresAt   DateTime?
  contentHash          String?
  metadata             Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  files          DocumentFile[]
  versions       DocumentVersion[]
  tags           DocumentTag[]
  workflowInstances WorkflowInstance[]
  accessControls DocumentAccessControl[]
  shareLinks      DocumentShareLink[]
  correspondences Correspondence[]
  comments        DocumentComment[]
  signatures      DocumentSignature[]
  relationsFrom   DocumentRelation[] @relation("RelationSource")
  relationsTo     DocumentRelation[] @relation("RelationTarget")
  redactions      DocumentRedaction[]
  subscriptions   DocumentSubscription[]
  externalLocks   DocumentExternalLock[]
  legalMatterDocs LegalMatterDocument[]
  bates           BatesStamp[]

  @@index([status])
  @@index([department])
  @@index([documentType])
  @@index([sourceSystem, sourceId])
  @@index([createdAt])
  @@index([securityClassification])
  @@map("documents")
}

// === Bates Numbering & eDiscovery ===
// Lawyer-grade sequential page identifiers (e.g. "KCAA-000001") for
// document productions. Each document gets a START and END Bates number;
// every page is stamped with the next number in the global sequence so a
// production can cite "KCAA-001247" to point at a specific page.

model BatesSequence {
  id          String   @id @default(cuid())
  name        String   @unique          // e.g. "KCAA-PROC-2026"
  prefix      String                    // e.g. "KCAA"
  pad         Int      @default(6)      // zero-padding width
  nextValue   Int      @default(1)      // next number to allocate
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productions BatesProduction[]

  @@map("bates_sequences")
}

model BatesProduction {
  id            String   @id @default(cuid())
  sequenceId    String
  sequence      BatesSequence @relation(fields: [sequenceId], references: [id])
  name          String                    // e.g. "First Production – 2026-Q1"
  startNumber   Int                       // inclusive Bates number where this run starts
  endNumber     Int?                      // inclusive end, null while in progress
  documentCount Int      @default(0)
  pageCount     Int      @default(0)
  createdById   String
  createdAt     DateTime @default(now())
  stamps        BatesStamp[]

  @@map("bates_productions")
}

model BatesStamp {
  id            String   @id @default(cuid())
  productionId  String
  production    BatesProduction @relation(fields: [productionId], references: [id], onDelete: Cascade)
  documentId    String
  document      Document @relation(fields: [documentId], references: [id])
  startNumber   Int
  endNumber     Int
  pageCount     Int
  stampedPath   String?                   // storage path of the stamped PDF copy
  stampedAt     DateTime @default(now())

  @@unique([productionId, documentId])
  @@index([documentId])
  @@map("bates_stamps")
}

/// Five-level government-grade security classification.
enum SecurityClassification {
  OPEN
  CONFIDENTIAL
  RESTRICTED
  SECRET
  TOP_SECRET
}

/// External-system reference lock. Active locks block deletion/replacement
/// but allow reads + new versions.
model DocumentExternalLock {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sourceSystem  String
  sourceType    String
  sourceRef     String
  lockedById    String?
  lockedAt      DateTime @default(now())
  reason        String?
  releasedAt    DateTime?
  releasedById  String?

  @@unique([documentId, sourceSystem, sourceRef])
  @@index([documentId, releasedAt])
  @@index([sourceSystem, sourceRef])
  @@map("document_external_locks")
}

// === Legal hold (eDiscovery matters) ===
model LegalMatter {
  id            String   @id @default(cuid())
  name          String
  matterNumber  String   @unique
  description   String?
  status        String   @default("OPEN")
  openedById    String
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  custodians    LegalMatterCustodian[]
  documents     LegalMatterDocument[]
  notices       LegalHoldNotice[]

  @@map("legal_matters")
}

model LegalMatterCustodian {
  id            String   @id @default(cuid())
  matterId      String
  matter        LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId        String?
  externalName  String?
  externalEmail String?
  notice        LegalHoldNotice?
  addedAt       DateTime @default(now())

  @@unique([matterId, userId])
  @@map("legal_matter_custodians")
}

model LegalMatterDocument {
  matterId   String
  matter     LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId String
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  addedById  String
  addedAt    DateTime    @default(now())

  @@id([matterId, documentId])
  @@map("legal_matter_documents")
}

model LegalHoldNotice {
  id             String   @id @default(cuid())
  matterId       String
  matter         LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)
  custodianId    String   @unique
  custodian      LegalMatterCustodian @relation(fields: [custodianId], references: [id], onDelete: Cascade)
  sentAt         DateTime @default(now())
  acknowledgedAt DateTime?
  ackToken       String   @unique

  @@map("legal_hold_notices")
}

model DocumentFile {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  storagePath  String   // file path or MinIO key
  fileName     String
  mimeType     String
  sizeBytes    BigInt
  isArchival   Boolean  @default(false)
  isThumbnail  Boolean  @default(false)
  ocrText      String?  @db.Text
  ocrStatus    OcrStatus @default(PENDING)
  encryptionIv String?
  encryptionTag String?
  renditionPath   String?   // PDF rendition for non-PDF files (Word/Excel/PPT)
  renditionStatus String    @default("NONE") // NONE, PENDING, DONE, FAILED
  /// Storage tier ("hot" | "warm" | "archive"). Set by the tiering worker.
  storageTier    String   @default("hot")
  /// Updated on each successful read; used by the tiering policy to decide
  /// when a file is cold enough to demote to a slower tier.
  lastAccessedAt DateTime?
  /// When this file last changed tier (used for cooldown / audit).
  tierMovedAt    DateTime?
  uploadedAt   DateTime @default(now())

  ocrWords     OcrWord[]

  @@index([storageTier, lastAccessedAt])
  @@map("document_files")
}

/// Per-word OCR bounding boxes extracted from a DocumentFile. Coordinates
/// are normalised to 0–1 against the page so they survive zoom + resize;
/// the client multiplies by the rendered page size in pixels.
model OcrWord {
  id           String       @id @default(cuid())
  fileId       String
  file         DocumentFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  page         Int                       // 1-based
  /// Normalised coords (0–1) — survive zoom + resize.
  x            Float
  y            Float
  width        Float
  height       Float
  text         String
  confidence   Float        @default(0)
  @@index([fileId, page])
  @@map("ocr_words")
}

/// Active tiering policy. Single-row by convention (isActive=true).
model StorageTierPolicy {
  id              String   @id @default(cuid())
  name            String   @unique
  isActive        Boolean  @default(true)
  /// Move to warm if hot + lastAccessed older than this many days.
  demoteToWarmDays    Int  @default(90)
  /// Move to archive if warm + lastAccessed older than this many days.
  demoteToArchiveDays Int  @default(365)
  /// Restore-on-access strategy when archive is read: "auto" | "manual"
  restoreStrategy String  @default("auto")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("storage_tier_policies")
}

model DocumentVersion {
  id              String              @id @default(cuid())
  documentId      String
  document        Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNum      Int
  storagePath     String
  fileName        String?
  mimeType        String?
  sizeBytes       BigInt
  changeNote      String
  label           String?             // user-defined label e.g. "FINAL", "APPROVED"
  status          VersionStatus       @default(DRAFT)
  isLatest        Boolean             @default(false)
  parentVersionId String?             // for rollback tracking
  encryptionIv    String?
  encryptionTag   String?
  approvedById    String?
  approvedBy      User?               @relation("VersionApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  createdById     String
  createdAt       DateTime            @default(now())

  @@unique([documentId, versionNum])
  @@index([documentId, isLatest])
  @@index([documentId, status])
  @@map("document_versions")
}

enum VersionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SUPERSEDED
  REJECTED
}


model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        String

  @@unique([documentId, tag])
  @@map("document_tags")
}

model DocumentAccessControl {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String?
  roleId     String?
  canRead    Boolean @default(true)
  canWrite   Boolean @default(false)
  canDelete  Boolean @default(false)
  canShare   Boolean @default(false)
  canPrint   Boolean @default(false)

  @@map("document_access_controls")
}

/// Tokenised share link for external (by-email) sharing of a document.
/// The token is an unguessable random string used in the public viewer URL.
/// Access through the link is streamed by our ACL-aware endpoint after token
/// validation (not expired, not revoked, matching documentId).
model DocumentShareLink {
  id           String    @id @default(cuid())
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token        String    @unique
  email        String?   // optional — when set, link was emailed to this address
  createdById  String
  createdBy    User      @relation("ShareLinkCreator", fields: [createdById], references: [id])
  canDownload  Boolean   @default(false)
  canPrint     Boolean   @default(false)
  expiresAt    DateTime?
  revokedAt    DateTime?
  revokedById  String?
  accessCount  Int       @default(0)
  lastAccessAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([documentId])
  @@index([token])
  @@index([email])
  @@map("document_share_links")
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  CHECKED_OUT
  ARCHIVED
  PENDING_DISPOSAL
  DISPOSED
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// === Workflow Engine ===
model WorkflowTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  definition   Json     // serialized node graph
  isActive     Boolean  @default(true)
  version      Int      @default(1)
  /// URL-safe slug used as the sidebar module route (e.g. "leave-request").
  /// When set, a published template appears as a standalone sidebar module.
  slug         String?  @unique
  /// Human label for a single instance (e.g. "Leave Request", "Purchase Order").
  instanceName String?
  /// Icon name from the workflow icon set shown in the sidebar.
  sidebarIcon  String?  @default("document")
  /// Ordering position among workflow sidebar modules (lower = higher).
  sidebarOrder Int      @default(0)
  /// Array of custom sub-view definitions shown in the sidebar module.
  /// Each entry: { id, label, description?, filter }
  /// filter values: "all" | "mine" | "mine_pending" | "overdue" | "step:<name>"
  customQueries Json    @default("[]")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  instances    WorkflowInstance[]
  triggers     WorkflowTrigger[]

  @@map("workflow_templates")
}

model WorkflowInstance {
  id                       String   @id @default(cuid())
  referenceNumber          String   @unique
  templateId               String
  template                 WorkflowTemplate @relation(fields: [templateId], references: [id])
  templateVersion          Int      @default(1)
  documentId               String?
  document                 Document? @relation(fields: [documentId], references: [id])
  initiatedById            String
  originalInitiatedById    String?
  parentInstanceId         String?  // for subprocess child instances
  parentSubprocessNodeId   String?  // subprocess node id on the parent template
  subject                  String
  status                   WorkflowStatus @default(PENDING)
  currentStepIndex         Int      @default(0)
  formData                 Json     @default("{}")
  version                  Int      @default(0)  // optimistic concurrency lock
  startedAt                DateTime @default(now())
  completedAt              DateTime?
  dueAt                    DateTime?

  tasks     WorkflowTask[]
  events    WorkflowEvent[]

  /// Initiator's chosen signature method at memo creation:
  /// "electronic" — embedded signature image rendered in the PDF.
  /// "digital"    — DocuSign envelope; cryptographic signature on top.
  /// Used by the memo view to suppress the "Claim ownership with a
  /// digital signature" prompt for memos already signed electronically.
  signatureMethod    String?
  /// DocuSign envelope id when the *initiator* has cryptographically signed
  /// the memo. Initiator-owned (like the electronic signature), not per-task.
  docusignEnvelopeId String?
  /// Last-known envelope status: sent, delivered, completed, declined, voided.
  docusignStatus     String?
  /// When the initiator completed the DocuSign envelope.
  docusignSignedAt   DateTime?
  /// Storage path of the downloaded, cryptographically signed PDF
  /// (combined with the certificate of completion).
  docusignSignedPdf  String?

  /// Nitro Sign transaction id — alternative cryptographic signing provider.
  /// Mirrors the DocuSign fields above; only one provider's fields will be
  /// populated for a given memo (initiator picks at memo creation time).
  nitroTransactionId String?
  nitroStatus        String?
  nitroSignedAt      DateTime?
  nitroSignedPdf     String?

  @@index([status])
  @@index([initiatedById])
  @@index([originalInitiatedById])
  @@index([docusignEnvelopeId])
  @@index([nitroTransactionId])
  @@map("workflow_instances")
}

model WorkflowTask {
  id              String   @id @default(cuid())
  instanceId      String
  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeId          String?
  stepName        String
  stepIndex       Int
  // Pool assignment — assigneeId is null until task is claimed from the pool
  poolId          String?
  pool            WorkflowPool? @relation(fields: [poolId], references: [id])
  assigneeId      String?
  assignee        User?    @relation("Assignee", fields: [assigneeId], references: [id])
  claimedById     String?
  claimedBy       User?    @relation("TaskClaimer", fields: [claimedById], references: [id])
  claimedAt       DateTime?
  taskType        TaskType @default(PRIMARY)
  status          TaskStatus @default(PENDING)
  action          TaskAction?
  comment         String?
  dueAt           DateTime?
  escalatedAt     DateTime?
  escalationLevel Int      @default(0)
  assignedAt      DateTime @default(now())
  completedAt     DateTime?
  comments        TaskComment[]
  attachments     TaskAttachment[]
  escalationLogs  TaskEscalationLog[]

  /// DocuSign envelope id when this task has been routed for digital
  /// signature. Used to look up signing status + download the signed PDF.
  docusignEnvelopeId String?
  /// Last-known DocuSign envelope status: SENT, DELIVERED, COMPLETED,
  /// DECLINED, VOIDED. Updated via the Connect webhook.
  docusignStatus     String?
  /// When the signer completed the DocuSign envelope.
  docusignSignedAt   DateTime?
  /// Storage path of the downloaded, cryptographically signed PDF.
  docusignSignedPdf  String?

  /// Nitro Sign transaction id — alternative cryptographic signing provider.
  /// Mirrors the DocuSign fields above.
  nitroTransactionId String?
  nitroStatus        String?
  nitroSignedAt      DateTime?
  nitroSignedPdf     String?

  @@index([instanceId])
  @@index([assigneeId, status])
  @@index([poolId, status])
  @@index([docusignEnvelopeId])
  @@index([nitroTransactionId])
  @@map("workflow_tasks")
}

model WorkflowPool {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     WorkflowPoolMember[]
  tasks       WorkflowTask[]

  @@map("workflow_pools")
}

model WorkflowPoolMember {
  id        String   @id @default(cuid())
  poolId    String
  pool      WorkflowPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("PoolMember", fields: [userId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([poolId, userId])
  @@map("workflow_pool_members")
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("CommentAuthor", fields: [authorId], references: [id])
  parentId   String?  // for threaded replies
  parent     TaskComment? @relation("CommentThread", fields: [parentId], references: [id])
  replies    TaskComment[] @relation("CommentThread")
  body       String
  isInternal Boolean  @default(false) // internal note not visible to initiator
  editedAt   DateTime?
  createdAt  DateTime @default(now())

  @@index([taskId])
  @@map("task_comments")
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  fileName     String
  storagePath  String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@map("task_attachments")
}

model WorkflowSignal {
  id          String    @id @default(cuid())
  signalKey   String    @unique // "{instanceId}:{nodeId}" — unique per wait point
  instanceId  String
  nodeId      String
  taskId      String?   // the placeholder task waiting for this signal
  receivedAt  DateTime?
  timedOutAt  DateTime?
  timeoutAt   DateTime? // wall-clock deadline; signal-timeout-worker fires when exceeded
  payload     Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([instanceId])
  @@index([timeoutAt]) // worker query index
  @@map("workflow_signals")
}

model WorkflowEvent {
  id         String   @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  eventType  String
  actorId    String?
  data       Json     @default("{}")
  occurredAt DateTime @default(now())

  @@index([instanceId])
  @@map("workflow_events")
}

model Delegation {
  id           String   @id @default(cuid())
  delegatorId  String
  delegator    User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegateId   String
  delegate     User     @relation("Delegate", fields: [delegateId], references: [id])
  reason       String
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean  @default(true)
  /// Source that created this delegation: "manual" | "leave_workflow" | "system"
  source       String   @default("manual")
  /// For leave-sourced delegations, the workflow instance that created it
  workflowInstanceId String?
  createdAt    DateTime @default(now())

  @@index([delegatorId, isActive])
  @@index([workflowInstanceId])
  @@map("delegations")
}

/// Per-user/role/department escalation chain configuration.
/// When a task assigned to a user exceeds the SLA, the engine walks
/// these levels to notify or reassign.
model EscalationMatrix {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  /// The subject this matrix applies to. At most one of these will be set.
  userId      String?  // specific user
  roleId      String?  // all users with this role
  department  String?  // all users in this department
  poolId      String?  // all tasks assigned to this workflow pool
  /// JSON array of escalation levels (ordered by level number):
  /// [{
  ///   level: 1,
  ///   afterHours: 24,            // wall-clock hours after task assignment (or prev level fire)
  ///   action: "notify"|"reassign"|"both",
  ///   escalateTo: "supervisor"|"user:{id}"|"role:{name}"|"department:{name}",
  ///   notifyOriginal: true,      // also remind the original assignee
  ///   message: "custom escalation message (optional)",
  /// }]
  levels      Json     @default("[]")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([roleId])
  @@map("escalation_matrices")
}

/// Records when each escalation level fired for a given task,
/// so we don't re-fire the same level twice.
model TaskEscalationLog {
  id           String      @id @default(cuid())
  taskId       String
  task         WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  matrixId     String?
  level        Int
  action       String      // notify | reassign | both
  escalatedTo  String?     // userId of the person notified/assigned
  firedAt      DateTime    @default(now())

  @@unique([taskId, level])
  @@index([taskId])
  @@map("task_escalation_logs")
}

model BusinessCalendar {
  id             String   @id @default(cuid())
  name           String   @unique
  timezone       String   @default("Africa/Nairobi")
  workdayStart   Int      @default(8)   // hour of day (24h), e.g. 8 = 08:00
  workdayEnd     Int      @default(17)  // hour of day (24h), e.g. 17 = 17:00
  workDays       Int[]    @default([1,2,3,4,5]) // 0=Sun,1=Mon,...,6=Sat
  holidays       Json     @default("[]") // array of "YYYY-MM-DD" strings
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("business_calendars")
}

model WorkflowTrigger {
  id             String   @id @default(cuid())
  name           String
  templateId     String
  template       WorkflowTemplate @relation(fields: [templateId], references: [id])
  /// "document" (default), "form_submit", "manual", "scheduled".
  triggerType    String   @default("document")
  /// For form_submit triggers — the source form template id.
  formTemplateId String?
  conditions     Json     // array of {field, operator, value} matching document metadata
  documentType   String?  // filter by document type (null = any)
  department     String?  // filter by department (null = any)
  subjectTemplate String? // template for workflow subject e.g. "Review: {{title}}"
  /// For scheduled triggers — 5-field cron expression.
  scheduleCron     String?
  scheduleTimezone String? @default("Africa/Nairobi")
  lastFiredAt      DateTime?
  nextFireAt       DateTime?
  isActive       Boolean  @default(true)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@index([triggerType, isActive])
  @@index([formTemplateId])
  @@index([triggerType, nextFireAt])
  @@map("workflow_triggers")
}

model WebhookLog {
  id           String   @id @default(cuid())
  instanceId   String
  nodeId       String
  url          String
  payload      Json
  status       String   @default("PENDING") // PENDING | SUCCESS | FAILED
  attempts     Int      @default(0)
  lastAttemptAt DateTime?
  responseCode Int?
  responseBody String?
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([instanceId])
  @@index([status, nextRetryAt])
  @@map("webhook_logs")
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum TaskType {
  PRIMARY
  CC
  BCC
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
  ESCALATED
}

enum TaskAction {
  APPROVED
  REJECTED
  RETURNED
  DELEGATED
}

// === Casefolder Access Control ===
model CasefolderACL {
  id              String   @id @default(cuid())
  formTemplateId  String   // the casefolder (FormTemplate) this ACL applies to
  userId          String?  // grant to a specific user
  roleId          String?  // OR grant to a role
  departmentId    String?  // OR grant to an entire department (by name)
  canView         Boolean  @default(true)   // can see the casefolder and its documents
  canCreate       Boolean  @default(false)  // can file new documents into the casefolder
  canEdit         Boolean  @default(false)  // can edit document metadata
  canDelete       Boolean  @default(false)  // can dispose/delete documents
  canShare        Boolean  @default(false)  // can share/circulate documents
  canDownload     Boolean  @default(false)  // can download documents
  canPrint        Boolean  @default(false)  // can print documents
  canManageACL    Boolean  @default(false)  // can manage access controls on this casefolder
  grantedById     String                    // who granted this access
  grantedAt       DateTime @default(now())
  expiresAt       DateTime?                 // optional expiry for temporary access
  notes           String?                   // reason for granting

  @@index([formTemplateId])
  @@index([userId])
  @@index([roleId])
  @@map("casefolder_acls")
}

// === Forms ===
model FormTemplate {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  fields      Json
  workflowTemplateId String?
  /// When true, the form is submittable from /public/forms/[id] without auth.
  isPublic    Boolean @default(false)
  isActive    Boolean @default(true)
  version     Int     @default(1)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissions FormSubmission[]

  @@map("form_templates")
}

model FormSubmission {
  id         String       @id @default(cuid())
  templateId String
  template   FormTemplate @relation(fields: [templateId], references: [id])
  submittedById String
  data       Json
  workflowInstanceId String?
  submittedAt DateTime   @default(now())

  @@map("form_submissions")
}

// === Audit, Notifications, Physical Records ===
model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  action       String
  resourceType String
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json     @default("{}")
  occurredAt   DateTime @default(now())
  /// Tamper-evident hash chain.
  prevHash     String?
  hash         String?
  /// SIEM shipment tracking — one row per outbound delivery attempt batch.
  siemShipLogs SiemShipLog[]

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([occurredAt])
  @@index([hash])
  @@map("audit_logs")
}

/// Backup-run ledger. One row per backup attempt, kept for retention policy.
model BackupLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  type         String                          // daily | weekly | monthly | manual
  dbDumpPath   String?
  uploadsPath  String?
  dbBytes      BigInt?
  uploadsBytes BigInt?
  durationMs   Int      @default(0)
  status       String                          // SUCCESS | FAILED
  error        String?

  @@index([timestamp])
  @@map("backup_logs")
}

/// Bulk migration import — walks a directory tree and ingests every file
/// as a Document. One job per directory; one row per file processed.
model BulkImportJob {
  id             String   @id @default(cuid())
  name           String
  sourcePath     String
  status         String   @default("PENDING")  // PENDING | RUNNING | COMPLETED | FAILED | CANCELLED
  totalFiles     Int      @default(0)
  processedFiles Int      @default(0)
  skippedFiles   Int      @default(0)
  failedFiles    Int      @default(0)
  department     String?
  documentType   String   @default("OTHER")
  tagsCsv        String?
  startedAt      DateTime?
  finishedAt     DateTime?
  error          String?
  createdById    String
  createdAt      DateTime @default(now())
  items          BulkImportItem[]

  @@map("bulk_import_jobs")
}

model BulkImportItem {
  id         String   @id @default(cuid())
  jobId      String
  job        BulkImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourcePath String                                // relative to job.sourcePath
  documentId String?
  status     String   @default("PENDING")        // PENDING | INGESTED | SKIPPED | FAILED
  error      String?
  bytes      BigInt   @default(0)

  @@index([jobId, status])
  @@map("bulk_import_items")
}

/// External SIEM shipment ledger.  One row per delivery lifecycle for a
/// given AuditLog: created PENDING, transitions to DELIVERED on a 2xx
/// from the configured target, or FAILED after the worker exhausts its
/// retry budget.  `attempts` increments on every send try so the worker
/// can cap retries and surface stuck events to admins.
model SiemShipLog {
  id          String    @id @default(cuid())
  auditLogId  String
  auditLog    AuditLog  @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  target      String    // "splunk_hec" | "syslog_udp" | "http_json"
  status      String    @default("PENDING") // PENDING | DELIVERED | FAILED
  attempts    Int       @default(0)
  lastError   String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
  @@map("siem_ship_logs")
}

/// Append-only search-query log for analytics.
model SearchLog {
  id           String   @id @default(cuid())
  userId       String?
  query        String
  filters      Json     @default("{}")
  resultCount  Int
  durationMs   Int      @default(0)
  hadResults   Boolean  @default(true)
  occurredAt   DateTime @default(now())

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([hadResults, occurredAt])
  @@map("search_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  sentEmail Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model PhysicalRecord {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  title           String
  boxNumber       String?
  shelfLocation   String?
  offSiteLocation String?
  barcode         String?  @unique
  documentId      String?
  status          PhysicalRecordStatus @default(AVAILABLE)
  checkedOutTo    String?
  checkedOutAt    DateTime?
  expectedReturnAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  movements       PhysicalRecordMovement[]

  @@map("physical_records")
}

model PhysicalRecordMovement {
  id               String         @id @default(cuid())
  physicalRecordId String
  physicalRecord   PhysicalRecord @relation(fields: [physicalRecordId], references: [id])
  action           String
  fromLocation     String?
  toLocation       String?
  performedById    String
  notes            String?
  occurredAt       DateTime       @default(now())

  @@map("physical_record_movements")
}

enum PhysicalRecordStatus {
  AVAILABLE
  CHECKED_OUT
  TRANSFERRED
  ARCHIVED
  DISPOSED
}

// === Document Capture (Hot Folder) ===
model DocumentRelation {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  source       Document @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       Document @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relationType String   // SUPERSEDES, SUPPORTS, RELATED_TO, TRANSLATES, REPLACES
  note         String?
  createdById  String
  createdBy    User     @relation("RelationCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
  @@map("document_relations")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  query     Json     // { search?, documentType?, department?, tags?, dateFrom?, dateTo?, status? }
  isPublic  Boolean  @default(false)
  icon      String?  // emoji or icon name
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_searches")
}

model DocumentRedaction {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fileId       String                        // source DocumentFile
  redactedPath String                        // storage path of redacted copy
  regions      Json     @default("[]")       // [{ page, x, y, width, height, reason }]
  reason       String?
  createdById  String
  createdBy    User     @relation("RedactionCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@index([documentId])
  @@map("document_redactions")
}

model DocumentSubscription {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation("DocumentWatcher", fields: [userId], references: [id], onDelete: Cascade)
  events       String[] // VERSION_UPLOADED, APPROVED, COMMENTED, STATUS_CHANGED, CHECKED_OUT
  createdAt    DateTime @default(now())

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@map("document_subscriptions")
}

model CaptureProfile {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  folderPath        String   // absolute path to the watched folder
  processedPath     String?  // move files here after processing (null = delete)
  errorPath         String?  // move failed files here
  fileTypes         String[] // allowed extensions: ["pdf", "docx", "tiff", "jpg"]
  pollingInterval   Int      @default(30) // seconds between scans
  isActive          Boolean  @default(true)
  formTemplateId    String?  // target casefolder (FormTemplate) for auto-classification
  department        String?  // default department for captured documents
  classificationNodeId String?
  metadataMapping   Json     @default("{}") // filename pattern → field mapping rules
  duplicateAction   String   @default("SKIP") // SKIP, VERSION, FLAG
  autoWorkflow      Boolean  @default(false)
  workflowTemplateId String?
  lastScanAt        DateTime?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  logs              CaptureLog[]

  // PDF processing options
  enableBlankPageRemoval Boolean @default(false)
  enablePdfA             Boolean @default(false)
  pdfALevel              String? @default("2b") // 1b | 2b | 3b

  // Phase 2: source routing
  sourceType        CaptureSourceType @default(HOT_FOLDER)
  priority          Int      @default(0)
  validationRules   Json     @default("{}")

  // IMAP email source
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPassword      String?
  imapFolder        String?  @default("INBOX")
  imapSenderFilter  String?
  imapSubjectFilter String?

  // SFTP / SMB remote source
  remoteHost        String?
  remotePort        Int?
  remoteUser        String?
  remotePassword    String?
  remotePath        String?
  remotePollInterval Int?    @default(60)
  remoteDeleteAfterCopy Boolean @default(false)

  exceptions        CaptureException[]
  triggers          CaptureTrigger[]

  @@map("capture_profiles")
}

model CaptureLog {
  id              String   @id @default(cuid())
  profileId       String
  profile         CaptureProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileName        String
  filePath        String
  fileSize        BigInt?
  fileHash        String?  // SHA-256 for duplicate detection
  status          CaptureStatus @default(PENDING)
  documentId      String?  // linked document if successfully captured
  errorMessage    String?
  metadata        Json     @default("{}")  // extracted metadata
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([profileId, status])
  @@index([fileHash])
  @@map("capture_logs")
}

enum CaptureStatus {
  PENDING
  PROCESSING
  CAPTURED
  DUPLICATE
  ERROR
  SKIPPED
  VALIDATION_FAILED
}

enum CaptureSourceType {
  HOT_FOLDER
  EMAIL
  API
  SFTP
  SMB
}

model CaptureException {
  id                 String   @id @default(cuid())
  profileId          String
  profile            CaptureProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  filePath           String
  extractedMetadata  Json     @default("{}")
  errors             Json     @default("[]")
  status             CaptureExceptionStatus @default(PENDING)
  resolvedById       String?
  resolvedBy         User?    @relation("CaptureExceptionResolver", fields: [resolvedById], references: [id])
  resolvedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([profileId, status])
  @@index([status])
  @@map("capture_exceptions")
}

enum CaptureExceptionStatus {
  PENDING
  RESOLVED
  REJECTED
}

model CaptureTrigger {
  id                 String   @id @default(cuid())
  profileId          String?
  profile            CaptureProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  documentTypeFilter String?
  studentFilter      String?
  channelType        CaptureTriggerChannel
  channelConfig      Json     @default("{}")
  enabled            Boolean  @default(true)
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([profileId, enabled])
  @@map("capture_triggers")
}

enum CaptureTriggerChannel {
  EMAIL
  WEBHOOK
  IN_APP
}

/// Rule-driven inbound email auto-ingest. Distinct from CaptureProfile
/// (sourceType=EMAIL) which drops attachments into a hot folder for the
/// main capture worker. This pipeline persists incoming mail directly as
/// Documents (one per message) with attachments as DocumentFiles.
model EmailIngestRule {
  id                 String   @id @default(cuid())
  name               String
  isActive           Boolean  @default(true)
  /// IMAP host config (per-rule so different mailboxes can land in different folders).
  imapHost           String
  imapPort           Int      @default(993)
  imapSecure         Boolean  @default(true)
  imapUser           String
  /// Encrypted password using lib/encryption (AES-256-GCM, enc:v1:... format).
  imapPasswordCipher String
  /// IMAP folder/mailbox to watch (e.g. "INBOX" or "Inbox/Procurement").
  mailbox            String   @default("INBOX")
  /// Optional From: header filter (substring match). null = any sender.
  fromFilter         String?
  /// Optional Subject: regex (raw). null = any subject.
  subjectFilter      String?
  /// Document target — either a casefolder slug/id or a freeform department.
  targetDepartment   String?
  targetDocumentType String   @default("EMAIL")
  /// Tag every ingested doc with this tag set.
  tagsCsv            String   @default("email,inbound")
  lastPolledAt       DateTime?
  lastError          String?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
  @@map("email_ingest_rules")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String    @unique
  hashedKey   String    @unique
  scope       String    @default("capture")
  createdById String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([scope, revokedAt])
  @@map("api_keys")
}


// ── Correspondence Register ──────────────────────────────────────────────

model Correspondence {
  id              String    @id @default(cuid())
  type            String    // INCOMING, OUTGOING, INTERNAL
  referenceNumber String    @unique
  subject         String
  fromEntity      String    // sender name/org (incoming) or department (outgoing)
  toEntity        String    // recipient dept (incoming) or external recipient (outgoing)
  dateReceived    DateTime? // for incoming
  dateSent        DateTime? // for outgoing
  dueDate         DateTime? // response deadline
  status          String    @default("DRAFT") // DRAFT, RECEIVED, REGISTERED, ASSIGNED, IN_PROGRESS, PENDING_APPROVAL, APPROVED, DISPATCHED, CLOSED, OVERDUE
  priority        String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  description     String?
  dispatchMethod  String?   // POST, COURIER, EMAIL, HAND_DELIVERY
  trackingNumber  String?   // courier tracking
  channel         String?   // EMAIL, LETTER, SYSTEM_UPLOAD, SCAN
  isConfidential  Boolean   @default(false)
  documentId      String?   // link to scanned document
  document        Document? @relation(fields: [documentId], references: [id])
  assignedToId    String?   // staff responsible for current action
  assignedTo      User?     @relation("CorrespondenceAssignee", fields: [assignedToId], references: [id])
  assignedRole    String?   // queue/role for assignment (e.g., REGISTRY_CLERK, HR_OFFICER)
  department      String?   // target department for routing
  currentStep     String    @default("CAPTURE") // current workflow step
  slaDeadline     DateTime? // SLA deadline for current step
  slaBreached     Boolean   @default(false)
  responseCorrespondenceId String? // link to outgoing response
  createdById     String
  createdBy       User      @relation("CorrespondenceCreator", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?
  metadata        Json      @default("{}")

  actionLogs      CorrespondenceActionLog[]

  @@index([type])
  @@index([status])
  @@index([currentStep])
  @@index([assignedToId])
  @@index([assignedRole])
  @@index([department])
  @@index([createdById])
  @@index([dateReceived])
  @@index([dateSent])
  @@index([slaBreached])
}

model CorrespondenceActionLog {
  id               String   @id @default(cuid())
  correspondenceId String
  correspondence   Correspondence @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)
  action           String   // CAPTURED, REGISTERED, ASSIGNED, REVIEWED, FORWARDED, APPROVED, REJECTED, DISPATCHED, CLOSED, ESCALATED, REASSIGNED
  fromStep         String   // step before action
  toStep           String   // step after action
  actorId          String
  comment          String?
  metadata         Json     @default("{}")
  occurredAt       DateTime @default(now())

  @@index([correspondenceId])
  @@index([actorId])
  @@index([occurredAt])
  @@map("correspondence_action_logs")
}

// === Student Portal Integration ===
model IntegrationSync {
  id            String   @id @default(cuid())
  sourceSystem  String   // STUDENT_PORTAL, ERP, LMS
  sourceId      String   // ID from source system
  documentId    String?  // linked EDRMS document
  syncStatus    String   // PENDING, SYNCED, FAILED
  metadata      Json     @default("{}")
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceSystem, sourceId])
  @@map("integration_syncs")
}

// === Document Comments / Discussion Threads ===
model DocumentComment {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  body        String
  parentId    String?  // null = top-level, set = reply
  parent      DocumentComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     DocumentComment[] @relation("CommentReplies")
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([documentId])
  @@index([parentId])
  @@index([authorId])
  @@map("document_comments")
}

// === Digital Signatures ===
model DocumentSignature {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signerId      String
  signer        User     @relation(fields: [signerId], references: [id])
  signatureType String   // DRAWN, TYPED, UPLOADED
  signatureData String   // base64 image (drawn), text (typed), or file path (uploaded)
  reason        String?  // e.g., "Approved", "Reviewed", "Witnessed"
  designation   String?  // signer's title at time of signing
  ipAddress     String?
  isVerified    Boolean  @default(true)
  signedAt      DateTime @default(now())

  @@index([documentId])
  @@index([signerId])
  @@map("document_signatures")
}

// === Disposition Certificates ===
model DispositionCertificate {
  id              String   @id @default(cuid())
  certificateNo   String   @unique
  disposalDate    DateTime
  disposalMethod  String   // SHREDDING, INCINERATION, DIGITAL_DELETION, RECYCLING
  approvedById    String
  approvedBy      User     @relation("DispositionApprover", fields: [approvedById], references: [id])
  witnessId       String?
  witness         User?    @relation("DispositionWitness", fields: [witnessId], references: [id])
  documentIds     Json     // array of document IDs disposed
  documentCount   Int
  remarks         String?
  status          String   @default("DRAFT") // DRAFT, APPROVED, EXECUTED
  createdAt       DateTime @default(now())
  executedAt      DateTime?

  @@index([approvedById])
  @@index([status])
  @@map("disposition_certificates")
}

// === Form Data Registry ===
// Generic structured data store. Admins define schemas (tables) and enter
// records (rows). Workflows query these at runtime via the lookup_form_data
// system action to drive conditional logic without external integrations.

model FormDataSchema {
  id          String   @id @default(cuid())
  name        String   @unique
  /// URL-safe slug used to reference this dataset from workflow conditions
  /// e.g. "leave_types", "leave_balances"
  slug        String   @unique
  description String?
  /// Field definitions: [{id, name, label, type, required, options?}]
  /// type: text | number | date | boolean | select | email | phone | user_ref
  fields      Json     @default("[]")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records     FormDataEntry[]

  @@map("form_data_schemas")
}

model FormDataEntry {
  id        String         @id @default(cuid())
  schemaId  String
  schema    FormDataSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  /// Arbitrary key-value data matching the parent schema's field definitions
  data      Json           @default("{}")
  createdById String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([schemaId])
  @@map("form_data_entries")
}

// === System Settings ===
// Key/value store for runtime-configurable settings (SMTP, branding, etc.)
// administered through the admin UI. Secret values are AES-256-GCM
// encrypted via lib/encryption and stored as { encrypted, iv, tag } JSON.
model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("AppSettingUpdater", fields: [updatedById], references: [id])

  @@map("app_settings")
}

// === User Sessions ===
// Server-side ledger of every issued refresh token, so we can:
//   - Show users their active sessions ("Other devices")
//   - Let users / admins revoke any session in real time
//   - Force-revoke all sessions on password change or admin reset
//   - Flag suspicious activity (many concurrent IPs, geo jumps, etc.)
model UserSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  /// Bcrypt hash of the rotating refresh token. Plaintext is never stored.
  refreshTokenHash String
  ipAddress       String?
  userAgent       String?
  /// Last time this session emitted a request (refreshed its access token).
  lastActiveAt    DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  /// Optional reason: USER_LOGOUT, PASSWORD_CHANGED, ADMIN_REVOKED,
  /// REVOKED_OTHER_DEVICES, EXPIRED, MFA_DISABLED.
  revokedReason   String?
  createdAt       DateTime @default(now())

  @@index([userId, revokedAt])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("user_sessions")
}

// === Login OTP ===
// Short-lived one-time code emailed to users who have enabled email MFA.
// Issued by /api/auth/mfa/request-code, consumed by the credentials
// authorize() flow on next sign-in. Only the bcrypt hash is persisted.
model LoginOtp {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLoginOtps", fields: [userId], references: [id], onDelete: Cascade)
  codeHash     String
  /// Hard expiry — 10 minutes after issue.
  expiresAt    DateTime
  /// Set when the code is successfully consumed at login.
  usedAt       DateTime?
  /// How many failed attempts have been made against this code.
  attempts     Int      @default(0)
  /// "LOGIN" (default) or "MFA_VERIFY" (used when verifying enable).
  purpose      String   @default("LOGIN")
  createdAt    DateTime @default(now())

  @@index([userId, usedAt, expiresAt])
  @@map("login_otps")
}

// === Login Attempts ===
// Append-only log of every authentication attempt — successful or not.
// Used for security visibility, anomaly detection, and to enforce
// IP-level rate limiting at the application layer.
model LoginAttempt {
  id            String   @id @default(cuid())
  email         String   // attempted email (may not exist)
  userId        String?  // populated when the email matched a user
  success       Boolean
  reason        String?  // INVALID_PASSWORD, ACCOUNT_LOCKED, MFA_REQUIRED, MFA_INVALID, EXPIRED_OTP, INACTIVE, OK
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId, createdAt])
  @@map("login_attempts")
}

// === Memo Drafts ===
// In-progress memo composer state, autosaved as the user types so closing
// the tab or navigating away never loses work. One row per active draft;
// deleted on successful submit.
model MemoDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("MemoDraftAuthor", fields: [userId], references: [id], onDelete: Cascade)
  /// Subject extracted from payload for display in the drafts list.
  subject   String   @default("Untitled draft")
  /// The full composer form state. Shape mirrors what /api/memos POST expects.
  payload   Json
  /// When the initiator chose Digital signature in the composer and signed
  /// the draft *before* submission, this is the storage path of the
  /// DocuSign-signed PDF (combined with the certificate of completion).
  /// On submit, the memo creation route attaches this file directly
  /// instead of regenerating an unsigned PDF.
  signedPdfPath      String?
  docusignEnvelopeId String?
  docusignStatus     String?
  docusignSignedAt   DateTime?
  /// Nitro Sign transaction id when the initiator signed via Nitro instead
  /// of DocuSign. Same lifecycle as the docusign fields above; signedPdfPath
  /// is shared (the most recently completed envelope/transaction wins).
  nitroTransactionId String?
  nitroStatus        String?
  nitroSignedAt      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("memo_drafts")
}

// === Presence ===
// Lightweight "who is currently viewing this resource" indicators.
// Clients heartbeat every ~10s while viewing a document/memo/workflow/form
// detail page; viewers active in the last 30s are considered present.
// Rows older than 24h are pruned by the cleanup worker.
model PresenceHeartbeat {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String   // "document" | "memo" | "workflow" | "form"
  resourceId   String
  lastSeenAt   DateTime @default(now())

  @@unique([userId, resourceType, resourceId])
  @@index([resourceType, resourceId, lastSeenAt])
  @@map("presence_heartbeats")
}

// === Translation Cache ===
// LLM-generated translations for strings missing from the static SW
// dictionary. Source-of-truth keys still live in `lib/i18n/locales/*.ts`;
// this table backs the runtime auto-translate fallback. Cached forever —
// admins can re-translate from the admin UI when the source dictionary
// changes.
// ─── Digitisation: Records survey + scan batch QA ────────────────────────────
// One-time pre-digitisation inventory of physical records, plus per-batch
// QA counters filled in by operators as they scan. This is the operational
// layer that lives alongside the existing CaptureProfile capture pipeline —
// CaptureProfile handles automatic file ingest; these models handle the
// manual quality-assurance workflow that auditors require.
model RecordsSurvey {
  id              String   @id @default(cuid())
  name            String
  location        String                            // e.g. "HQ Main Registry — Cabinet 4"
  estimatedVolume Int      @default(0)              // estimated document count
  actualVolume    Int      @default(0)              // counted during survey
  boxCount        Int      @default(0)
  earliestDate    String?                           // free text e.g. "1972"
  latestDate      String?
  condition       String   @default("FAIR")         // GOOD | FAIR | POOR
  notes           String?
  status          String   @default("PLANNED")      // PLANNED | IN_PROGRESS | COMPLETED
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  scanBatches     ScanBatch[]

  @@map("records_surveys")
}

model ScanBatch {
  id               String   @id @default(cuid())
  surveyId         String?
  survey           RecordsSurvey? @relation(fields: [surveyId], references: [id])
  batchNumber      String   @unique
  operator         String                           // staff name
  scanner          String                           // make/model
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  expectedPages    Int      @default(0)
  actualPages      Int      @default(0)
  legibleCount     Int      @default(0)
  illegibleCount   Int      @default(0)
  skewedCount      Int      @default(0)
  blankCount       Int      @default(0)
  missingCount     Int      @default(0)
  notes            String?
  status           String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | REJECTED
  createdById      String

  @@map("scan_batches")
}

model TranslationCache {
  id            String   @id @default(cuid())
  sourceLocale  String   // "en"
  targetLocale  String   // "sw"
  sourceText    String   @db.Text
  targetText    String   @db.Text
  /// sha256(sourceLocale + "|" + targetLocale + "|" + sourceText) — keeps
  /// the unique constraint workable when sourceText is large.
  keyHash       String
  /// When non-null, the cache entry was overridden by a human admin and
  /// should be left alone by bulk re-translate runs.
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([keyHash])
  @@index([targetLocale])
  @@map("translation_cache")
}

/// Per-user customisable dashboard layout. The `widgets` JSON is an array
/// of widget descriptors of the form:
///   { id, type, title, x, y, w, h, config: { ... } }
/// Where x/y/w/h are integer cells on a 12-column CSS grid. The catalogue
/// of widget types lives in `lib/widgets.ts`. Data is *never* stored here
/// — widgets fetch live aggregates from /api/dashboard/data.
model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets   Json     @default("[]")
  updatedAt DateTime @updatedAt

  @@map("dashboard_layouts")
}

