# ─────────────────────────────────────────────────────────────────────────────
# Karatina University EDRMS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host/karatina_edrms?sslmode=require"
DIRECT_URL="postgresql://user:password@host/karatina_edrms?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-secure-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# File Encryption (AES-256-GCM) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Logging level: debug | info | warn | error
LOG_LEVEL="info"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@karu.ac.ke"

# Student Portal Integration
STUDENT_PORTAL_API_URL="http://localhost:3001/api"
STUDENT_PORTAL_API_KEY=""
