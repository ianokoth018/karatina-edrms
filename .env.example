# ─────────────────────────────────────────────────────────────────────────────
# Karatina University EDRMS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host/karatina_edrms?sslmode=require"
DIRECT_URL="postgresql://user:password@host/karatina_edrms?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-secure-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# File Encryption (AES-256-GCM) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Logging level: debug | info | warn | error
LOG_LEVEL="info"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@karu.ac.ke"

# Student Portal Integration
STUDENT_PORTAL_API_URL="http://localhost:3001/api"
STUDENT_PORTAL_API_KEY=""

# ClamAV — on-ingest malware scanning. Disabled by default so dev/CI without
# a clamd daemon doesn't block uploads. In production set CLAMAV_ENABLED=true
# and point CLAMAV_HOST/PORT at a reachable clamd. CLAMAV_FAIL_MODE controls
# what happens when the scanner is unreachable: "closed" (default) rejects
# the upload, "open" lets it through with a logged warning.
CLAMAV_ENABLED="false"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="30000"
CLAMAV_MAX_BYTES="104857600"
CLAMAV_FAIL_MODE="closed"
